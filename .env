# ==========================================
# JWT SOZLAMALARI
# ==========================================
JWT_SECRET=silence_ai_super_secret_key_2024
JWT_EXPIRES_IN=24h

# ==========================================
# SERVER
# ==========================================
PORT=3000

# ==========================================
# TELEGRAM BOT
# ==========================================
# 1. @BotFather ga /newbot buyrug'ini yuboring
# 2. Bot token olasiz, quyiga kiriting:
TELEGRAM_BOT_TOKEN=your_bot_token_here

# 3. Chat ID olish uchun:
#    - Botingizga /start yuboring
#    - Keyin: https://api.telegram.org/bot<TOKEN>/getUpdates
#    - "chat":{"id": XXXXX} — shu raqam
TELEGRAM_CHAT_ID=your_chat_id_here

# ==========================================
# ADMIN FOYDALANUVCHI (Birinchi ishga tushganda)
# ==========================================
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=silence123
